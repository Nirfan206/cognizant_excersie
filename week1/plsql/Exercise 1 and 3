Scenario 2: Promote Customers to VIP Status
Code
BEGIN
    FOR cust IN (
        SELECT CustomerID
        FROM Customers
        WHERE Balance > 10000
    )
    LOOP
        UPDATE Customers
        SET IsVIP = 'TRUE'
        WHERE CustomerID = cust.CustomerID;

        DBMS_OUTPUT.PUT_LINE(
            'VIP Status assigned to Customer ID: ' || cust.CustomerID
        );
    END LOOP;

    COMMIT;
END;
/
Output
VIP Status assigned to Customer ID: 102
VIP Status assigned to Customer ID: 105
