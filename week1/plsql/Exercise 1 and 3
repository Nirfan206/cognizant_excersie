Scenario 3: Loan Due Reminder
Code
BEGIN
    FOR loan_rec IN (
        SELECT CustomerID, LoanID, DueDate
        FROM Loans
        WHERE DueDate BETWEEN SYSDATE AND SYSDATE + 30
    )
    LOOP
        DBMS_OUTPUT.PUT_LINE(
            'Reminder: Loan ID ' || loan_rec.LoanID ||
            ' for Customer ID ' || loan_rec.CustomerID ||
            ' is due on ' || loan_rec.DueDate
        );
    END LOOP;
END;
/
Output
Reminder: Loan ID 201 for Customer ID 101 is due on 15-JUL-26
Reminder: Loan ID 203 for Customer ID 103 is due on 10-JUL-26
